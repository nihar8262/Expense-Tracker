{
  "installCommand": "npm install",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains; preload"
        }
      ]
    }
  ],
  "buildCommand": "npm run build --workspace frontend",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/tokens",
      "destination": "/api/account?tokens=true"
    },
    {
      "source": "/api/tokens/:route*",
      "destination": "/api/account?tokensRoute=:route*"
    },
    {
      "source": "/api/mcp/:route*",
      "destination": "/api/mcp?route=:route*"
    },
    {
      "source": "/api/assistant/:route*",
      "destination": "/api/assistant?route=:route*"
    },
    {
      "source": "/api/receipts",
      "destination": "/api/expenses?receipts=true"
    },
    {
      "source": "/api/expenses/:route*",
      "destination": "/api/expenses?route=:route*"
    },
    {
      "source": "/api/budgets/:route*",
      "destination": "/api/budgets?route=:route*"
    },
    {
      "source": "/api/notifications/:route*",
      "destination": "/api/notifications?route=:route*"
    },
    {
      "source": "/api/wallets/:route*",
      "destination": "/api/wallets?route=:route*"
    },
    {
      "source": "/api/bill-reminders/:route*",
      "destination": "/api/bill-reminders?route=:route*"
    },
    {
      "source": "/api/wallet-invites/:route*",
      "destination": "/api/wallet-invites?route=:route*"
    },
    {
      "source": "/api/internal/:route*",
      "destination": "/api/internal?route=:route*"
    },
    {
      "source": "/((?!api/|assets/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}